{
  "name": "project-atlas",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run server:build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server:dev": "tsx --tsconfig tsconfig.server.json server/src/main.ts",
    "server:build": "tsc -p tsconfig.server.json",
    "start": "node dist-server/src/main.js",
    "test": "vitest run",
    "qmd:add": "qmd collection add ./.specify --name specify --mask \"**/*.{md,facts}\" --overwrite",
    "qmd:embed": "qmd embed",
    "qmd:search": "qmd search"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "ioredis": "^5.5.0",
    "pg": "^8.21.0",
    "pg-mem": "^3.0.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tobilu/qmd": "^2.5.3",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
